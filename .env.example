# ============================================================
# Supabase
# ============================================================
# URL del proyecto (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Anon key — público, va al browser (Settings → API → Project API keys → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SECRETO, server-only (Settings → API → Project API keys → service_role)
# NUNCA exponer al browser. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=
